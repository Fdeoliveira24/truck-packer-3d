# Dependencies
node_modules/
package-lock.json

# Reports
cleanup/reports/*.txt
cleanup/reports/*.log
cleanup/reports/*.json
!cleanup/reports/.gitkeep
test-results/
eslint-report.json
grep_*.txt
supabase_push_error.txt

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Local backups
index-backup.html

# Supabase database backups (local only — never commit)
backups/*.sql
backups/*.dump
backups/*.gz
backups/*.zip

# IDE
.vscode/
.idea/
*.swp
*.swo
*.iml
.agents/
.windsurf/
skills/
skills-lock.json

# Build outputs
dist/
build/
*.min.js
*.min.css
!vendor/*.min.js
# ^ Exception: Keep vendor files for offline fallback

# Temporary files
*.tmp
*.temp
.cache/
.npm-cache/

# Secrets — never commit
.env
.env.local
*.env.local
supabase/functions/.env.local
.claude/
