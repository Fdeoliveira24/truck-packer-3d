# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# Supabase project credentials (Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Dashboard → Developers → API keys)
# Fixture tooling accepts test-mode keys only and allowlisted dev/test projects.
# Keep real secrets in local/CI secret stores; never commit them to source control.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe price IDs (Dashboard → Products → Prices)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Optional Business Price recognition. Business remains checkout-disabled.
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# Optional comma-separated legacy Price recognition. These IDs remain valid
# for existing subscribers and workspace-limit resolution, but are never
# eligible for new checkout. Unknown active Prices keep conservative Pro
# fallback access and billing-status reports unknownPriceId=true.
STRIPE_PRICE_PRO_MONTHLY_LEGACY=price_legacy_month_1,price_legacy_month_2
STRIPE_PRICE_PRO_YEARLY_LEGACY=price_legacy_year_1
STRIPE_PRICE_BUSINESS_MONTHLY_LEGACY=price_legacy_business_month_1
STRIPE_PRICE_BUSINESS_YEARLY_LEGACY=price_legacy_business_year_1

# Optional workspace-limit overrides. Invalid or missing values use current defaults.
TP3D_TRIAL_WORKSPACE_LIMIT=1
TP3D_PRO_WORKSPACE_LIMIT=3
TP3D_BUSINESS_WORKSPACE_LIMIT=10

# Allowed CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=https://yourdomain.com

# Optional: Stripe billing portal configuration ID
# STRIPE_PORTAL_CONFIGURATION_ID=bpc_...

# Optional: override the site URL used in invite emails
# SUPABASE_SITE_URL=https://yourdomain.com
